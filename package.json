    "url": "https://github.com/felix-berlin/berliner-schnauze/issues"
  },
  "author": {
    "name": "Felix Scholze",
    "email": "felix@webshaped.de",
    "url": "https://webshaped.de"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/felix-berlin/berliner-schnauze"
  },
  "funding": [
    {
      "type": "GitHub Sponsors",
      "url": "https://github.com/sponsors/felix-berlin"
    },
    {
      "type": "Ko-fi",
      "url": "https://ko-fi.com/felixberlin"
    },
    {
      "type": "PayPal",
      "url": "https://paypal.me/FelixScholze"
    },
    {
      "type": "Buy me a coffee",
      "url": "https://www.buymeacoffee.com/felixberlin"
    }
  ],
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "pnpm run supportedBrowsers && astro build",
    "build:strict": "astro check && tsc --noEmit && vue-tsc --noEmit && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typechecking": "astro check && tsc --noEmit && vue-tsc --noEmit",
    "lint:js": "eslint src/ --ignore-pattern 'src/tests/*'",
    "lint:style": "stylelint \"**/*.{scss,sass}\" --ignore-path .gitignore",
    "lint": "pnpm run lint:js && pnpm run lint:style",
    "test:unit": "vitest run --coverage",
    "test:unit:watch": "vitest --coverage",
    "test:unit:ui": "vitest --coverage --ui",
    "test:ci": "vitest run --coverage --reporter=default --reporter=junit",
    "vitest:update": "vitest --update",
    "format": "pnpm exec oxfmt .",
    "format:check": "pnpm exec oxfmt --check .",
    "gql:generate": "graphql-codegen --config codegen.ts",
    "gql:generate:watch": "graphql-codegen --config codegen.ts --watch",
    "generate-pwa-assets": "pwa-assets-generator --preset minimal-2023 public/favicons/favicon.svg",
    "browserslist:update": "pnpx update-browserslist-db@latest",
    "predev": "pnpm run gql:generate && pnpm run supportedBrowsers",
    "preinstall": "pnpx only-allow pnpm",
    "server:pages": "pnpx wrangler pages dev ./dist",
    "supportedBrowsers": "echo \"export default $(browserslist-useragent-regexp --allowHigherVersions);\" > src/utils/supportedBrowsers.mjs",
    "refreshAuthToken": "node --env-file=.env ./src/utils/refreshToken.js"
  },
  "dependencies": {
    "@astrojs/partytown": "^2.1.5",
    "@astrojs/sitemap": "^3.7.1",
    "@astrojs/vue": "^6.0.0",
    "@felix_berlin/sass-butler": "3.1.1",
    "@iconify-json/lucide": "^1.2.97",
    "@nanostores/persistent": "^1.3.3",
    "@nanostores/vue": "^1.1.0",
    "@orama/orama": "^3.1.18",
    "@orama/plugin-match-highlight": "^3.1.18",
    "@orama/stemmers": "^3.1.18",
    "@sentry/astro": "^10.43.0",
    "@sentry/vite-plugin": "^5.1.1",
    "@spotlightjs/astro": "^3.2.6",
    "@urql/core": "^6.0.1",
    "@urql/vue": "^2.0.0",
    "@vueform/multiselect": "^2.6.11",
    "@vueuse/core": "^14.2.1",
    "astro": "^6.0.4",
    "astro-breadcrumbs": "^3.4.0",
    "astro-matomo": "^1.10.0",
    "compromise": "^14.15.0",
    "de-compromise": "^0.0.10",
    "floating-vue": "5.2.2",
    "hyphenation.de": "^0.2.1",
    "hypher": "^0.2.5",
    "nanostores": "^1.1.1",
    "natural": "^8.1.1",
    "photoswipe": "^5.4.4",
    "vanilla-cookieconsent": "3.1.0",
    "virtua": "^0.48.7",
    "vite-plugin-pwa": "^1.2.0",
    "vue": "^3.5.30",
    "workbox-build": "^7.4.0",
    "workbox-window": "^7.4.0"
  },
  "devDependencies": {
    "@0no-co/graphqlsp": "^1.15.2",
    "@astrojs/check": "^0.9.7",
    "@codecov/astro-plugin": "^1.9.1",
    "@eslint/js": "^10.0.1",
    "@graphql-codegen/cli": "^6.2.1",
    "@graphql-codegen/client-preset": "^5.2.4",
    "@graphql-codegen/introspection": "^5.0.1",
    "@graphql-codegen/schema-ast": "^5.0.1",
    "@graphql-codegen/typescript": "^5.0.9",
    "@graphql-codegen/typescript-operations": "^5.0.9",
    "@graphql-eslint/eslint-plugin": "^4.4.0",
    "@nanostores/logger": "^1.1.0",
    "@playform/inline": "^0.1.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@sentry/browser": "^10.43.0",
    "@types/jsdom": "^28.0.0",
    "@types/node": "^25.5.0",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vite-pwa/astro": "^1.2.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "4.1.4",
