    "url": "https://webshaped.de"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/felix-berlin/berliner-schnauze"
  },
  "funding": [
    {
      "type": "GitHub Sponsors",
      "url": "https://github.com/sponsors/felix-berlin"
    },
    {
      "type": "Ko-fi",
      "url": "https://ko-fi.com/felixberlin"
    },
    {
      "type": "PayPal",
      "url": "https://paypal.me/FelixScholze"
    },
    {
      "type": "Buy me a coffee",
      "url": "https://www.buymeacoffee.com/felixberlin"
    }
  ],
  "type": "module",
  "scripts": {
    "dev": "infisical run -- astro dev",
    "start": "astro dev",
    "build": "pnpm run supportedBrowsers && astro build",
    "build:local": "infisical run -- pnpm run build",
    "build:strict": "astro check && tsc --noEmit && vue-tsc --noEmit && astro build",
    "preview": "astro preview",
    "astro": "astro",
    "typechecking": "astro check && vue-tsc --noEmit",
    "lint:js": "pnpm run lint:js:oxlint",
    "lint:js:oxlint": "oxlint src/ --deny-warnings --fix --fix-suggestions",
    "lint:style": "stylelint \"**/*.{scss,sass}\" --ignore-path .gitignore --fix",
    "lint": "pnpm run lint:js && pnpm run lint:style",
    "test:unit": "vitest run --coverage",
    "test:unit:watch": "vitest --coverage",
    "test:unit:ui": "vitest --coverage --ui",
    "test:ci": "vitest run --coverage --reporter=default --reporter=junit",
    "vitest:update": "vitest --update",
    "format": "pnpm exec oxfmt .",
    "format:check": "pnpm exec oxfmt --check .",
    "gql:generate": "infisical run -- graphql-codegen --config codegen.ts",
    "gql:generate:watch": "infisical run -- graphql-codegen --config codegen.ts --watch",
    "generate-pwa-assets": "pwa-assets-generator --preset minimal-2023 public/favicons/favicon.svg",
    "browserslist:update": "pnpx update-browserslist-db@latest",
    "predev": "pnpm run gql:generate && pnpm run supportedBrowsers",
    "preinstall": "pnpx only-allow pnpm",
    "server:preview": "pnpx wrangler pages dev ./dist",
    "server:build:preview": "pnpm build && pnpm server:preview",
    "supportedBrowsers": "echo \"export default $(browserslist-useragent-regexp --allowHigherVersions);\" > src/utils/supportedBrowsers.mjs",
    "refreshAuthToken": "node --env-file=.env ./src/utils/refreshToken.js"
  },
  "dependencies": {
    "@astrojs/partytown": "^2.1.7",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vue": "^7.0.1",
    "@felix_berlin/sass-butler": "3.1.1",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@iconify-json/lucide": "^1.2.117",
    "@nanostores/async": "^0.1.0",
    "@nanostores/persistent": "^1.3.4",
    "@nanostores/vue": "^1.1.0",
    "@orama/highlight": "^0.1.9",
    "@orama/orama": "^3.1.18",
    "@orama/stemmers": "^3.1.18",
    "@sentry/vite-plugin": "^5.4.0",
    "@spotlightjs/astro": "^3.2.6",
    "@urql/core": "^6.0.3",
    "@urql/vue": "^2.1.1",
    "@vueform/multiselect": "^2.6.11",
    "@vueuse/core": "^14.3.0",
    "all-the-german-words": "^1.1.0",
    "astro": "^7.0.9",
    "astro-breadcrumbs": "^3.4.1",
    "astro-matomo": "^1.12.0",
    "astro-og-canvas": "^0.13.0",
    "canvaskit-wasm": "^0.41.1",
    "compromise": "^14.15.1",
    "de-compromise": "^0.1.0",
    "hyphenation.de": "^0.2.1",
    "hypher": "^0.2.5",
    "nanostores": "^1.4.0",
    "natural": "^8.1.1",
    "photoswipe": "^5.4.4",
    "vanilla-cookieconsent": "3.1.0",
    "virtua": "^0.49.3",
    "vite-plugin-pwa": "^1.3.0",
    "vue": "^3.5.39",
    "workbox-build": "^7.4.1",
    "workbox-window": "^7.4.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@0no-co/graphqlsp": "^1.17.3",
    "@astrojs/check": "^0.9.9",
    "@codecov/astro-plugin": "^2.0.1",
    "@graphql-codegen/cli": "^7.1.3",
    "@graphql-codegen/client-preset": "^6.0.1",
    "@graphql-codegen/introspection": "^6.0.1",
    "@graphql-codegen/schema-ast": "^6.0.1",
    "@graphql-codegen/typescript": "^6.0.2",
    "@graphql-codegen/typescript-operations": "^6.0.5",
    "@infisical/cli": "^0.43.99",
    "@nanostores/logger": "^1.1.0",
    "@playform/inline": "^0.1.4",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@sentry/browser": "^10.65.0",
