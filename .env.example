# WordPress MCP server (.mcp.json → berlinerSchnauze)
# Application Password: WP Profil → Application Passwords generieren, NICHT Hauptpasswort nutzen.
# Save in user settings `~/.claude/settings.json` under "env".
WP_MCP_API_URL=https://website.com/wp-json/mcp/mcp-adapter-default-server
WP_MCP_USERNAME=
WP_MCP_PASSWORD=
