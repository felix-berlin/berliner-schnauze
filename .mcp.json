{
  "mcpServers": {
    "berlinerSchnauze": {
      "command": "npx",
      "args": ["-y", "@automattic/mcp-wordpress-remote@latest"],
      "env": {
        "WP_API_URL": "${WP_MCP_API_URL}",
        "WP_API_USERNAME": "${WP_MCP_USERNAME}",
        "WP_API_PASSWORD": "${WP_MCP_PASSWORD}"
      }
    }
  }
}
