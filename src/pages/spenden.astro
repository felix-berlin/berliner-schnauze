---
import '@styles/components/_button.scss';
import '@styles/components/_donation-page.scss';
import '@styles/components/_section-card.scss';
import DonationWallets from '@components/DonationWallets.vue';
import Layout from '@layouts/Layout.astro';
import { fetchFundingData } from '@services/queries/getCompanyFunding';

const { platforms, wallets } = await fetchFundingData();

const page = {
  seo: {
    opengraphDescription:
      "Berliner Schnauze is' kostenlos und werbefrei. Wenn de dit Projekt unterstützen willst: Hier findste alle Spendenwege — von PayPal bis Krypto.",
  },
  title: 'Spenden - Berliner Schnauze',
};
---

<Layout content={page}>
  <div class='c-donation-page'>
    <h1>Haste mal nen Euro?</h1>

    <p class='c-donation-page__intro'>
      Berliner Schnauze is' komplett kostenlos — keene Werbung, keen Schnickschnack, keene
      versteckten Kosten. Wat trotzdem anfällt: Hosting, Domain und ne janze Menge Zeit. Wenn de
      Bock hast, dit Projekt zu unterstützen, findste hier alle Wege. Allet freiwillig, versteht
      sich.
    </p>

    <section
      class='c-section-card c-donation-page__section'
      aria-labelledby='heading-plattformen'
    >
      <div class='c-section-card__header'>
        <span class='c-section-card__num'></span>
        <h2 class='c-section-card__title' id='heading-plattformen'>Plattformen</h2>
      </div>
      <div class='c-section-card__body'>
        <p>Der klassische Weg — einmalig oder regelmäßig, janz wie de willst.</p>
        <ul class='c-donation-page__platform-list u-list-reset'>
          {
            platforms.map((platform) => (
              <li class='c-donation-page__platform-item'>
                <a
                  class='c-button c-donation-page__platform-link'
                  href={platform.link}
                  rel='noopener'
                  target='_blank'
                >
                  {platform.name}
                </a>
              </li>
            ))
          }
        </ul>
      </div>
    </section>

    <section class='c-section-card c-donation-page__section' aria-labelledby='heading-krypto'>
      <div class='c-section-card__header'>
        <span class='c-section-card__num'></span>
        <h2 class='c-section-card__title' id='heading-krypto'>Krypto</h2>
      </div>
      <div class='c-section-card__body'>
        <p>Für die Krypto-Freunde: Adresse kopieren, Coins rüberschicken, fertich.</p>
        <DonationWallets client:visible wallets={wallets} />
      </div>
    </section>
  </div>
</Layout>
