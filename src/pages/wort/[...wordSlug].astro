---
// Styles
import '@styles/objects/_word.scss';
import '@styles/components/_single-word.scss';
import '@styles/components/_section-card.scss';
import '@styles/plugins/astro-breadcrumbs.scss';

// Types
import type { GetStaticPaths, InferGetStaticParamsType, InferGetStaticPropsType } from 'astro';

import ImageGallery from '@components/ImageGallery.astro';
import RandomWordButton from '@components/RandomWordButton.vue';
import RelatedWords from '@components/RelatedWords.vue';
import WordExamples from '@components/word/WordExamples.astro';
import WordAlphabetNav from '@components/word/WordAlphabetNav.astro';
import WordAnagrams from '@components/word/WordAnagrams.astro';
import WordHero from '@components/word/WordHero.astro';
import WordSectionEtymologie from '@components/word/WordSectionEtymologie.astro';
import WordSectionGrammatik from '@components/word/WordSectionGrammatik.astro';
import WordSectionLinguistik from '@components/word/WordSectionLinguistik.astro';
import WordSectionOrthographie from '@components/word/WordSectionOrthographie.astro';
import WordSectionPhonologie from '@components/word/WordSectionPhonologie.astro';
import BookRecommendations from '@components/word/BookRecommendations.astro';
import WordSidebar from '@components/word/WordSidebar.astro';
import Layout from '@layouts/Layout.astro';
import { fetchAllWords } from '@services/api.ts';
import { formattedDate, routeToWord, seoData, canonicalUrl } from '@utils/helpers.ts';
import {
  alphabeticNeighbors,
  findAnagrams,
  getWordType,
  similarSoundingWords,
  similarWords,
  translateNlpTags,
} from '@utils/wordHelper.ts';
import type { WordRef } from '@utils/wordHelper.ts';
import { Breadcrumbs } from 'astro-breadcrumbs';
import ChevronRight from '~icons/lucide/chevron-right';
import ExternalLink from '~icons/lucide/external-link';

import type { BerlinerWord } from '@/gql/entity-types';

export const getStaticPaths = (async () => {
  const allWords = await fetchAllWords();
  const wordRefs: WordRef[] = allWords.map(({ node }) => ({
    id: node.id,
    slug: node.slug,
    wordProperties: { berlinerisch: node.wordProperties?.berlinerisch },
  }));

  return allWords.map(({ node }, i) => {
    const wordRef = wordRefs[i]!;
    const berlinerisch = node.wordProperties?.berlinerisch ?? '';
    return {
      params: {
        wordSlug: node.slug ?? undefined,
      },
      props: {
        alphabeticNeighborsResult: alphabeticNeighbors(wordRefs, wordRef),
        anagramsResult: findAnagrams(berlinerisch, wordRefs),
        similarSpellingResult: similarWords(wordRefs, wordRef)
          .filter((w) => w.isSimilar >= 0.85)
          .sort((a, b) => b.isSimilar - a.isSimilar)
          .slice(0, 5)
          .map((w) => w.word),
        soundingWordsResult: similarSoundingWords(wordRefs, wordRef)
          .filter((r) => r.isSimilar)
          .map((r) => r.word),
        word: node,
        wordRefs,
      },
    };
  });
}) satisfies GetStaticPaths;

type Params = InferGetStaticParamsType<typeof getStaticPaths>;
type Props = InferGetStaticPropsType<typeof getStaticPaths>;

const { wordSlug } = Astro.params as Params;
const { word, wordRefs, alphabeticNeighborsResult, anagramsResult, soundingWordsResult, similarSpellingResult } =
  Astro.props;

const wordProps: BerlinerWord['wordProperties'] = word.wordProperties;

const wordDescription = (() => {
  const translations = (wordProps?.translations ?? [])
    .map((t) => t?.translation)
    .filter(Boolean)
    .join(', ');
  if (!translations) return undefined;
  const berlinerisch = wordProps?.berlinerisch ?? '';
  const raw = `„${berlinerisch}" bedeutet auf Berlinerisch: ${translations}. Entdecke Berliner Ausdrücke auf Berliner Schnauze.`;
  return raw.length > 160 ? raw.slice(0, 157) + '…' : raw;
})();

const alternativeWords = wordProps?.alternativeWords?.map((word, index) => {
  return (
    word?.alternativeWord +
    (wordProps?.alternativeWords && index !== wordProps?.alternativeWords?.length - 1 ? ', ' : '')
  );
});

// const wikimediaFiles = await createWikimediaFileList(wordProps?.wikimediaFiles!);
// console.log(wikimediaFiles);

let galleryWidths = [316, 457, 658, 429, 525];
let gallerySizes =
  '(max-width: 80rem) 525px, (max-width: 64rem) 429px, (max-width: 48rem) 658px, (max-width: 35.49rem) 457px, (max-width: 26.6rem) 316px';
const lightboxWidths = [425, 567, 768, 896];
const lightboxSizes =
  '(max-width: 26.6rem) 425px, (max-width: 35.49rem) 567px, (max-width: 48rem) 768px, (max-width: 64rem) 896px';

if (wordProps?.images && wordProps?.images?.nodes.length > 1) {
  galleryWidths = [503, 435, 307];
  gallerySizes =
    '(max-width: 70rem) 503px, (max-width: 64rem) 435px, (max-width: 48rem) 307px, (max-width: 35.5rem) 435px, (max-width: 27.2rem) 307px';
}

const wordTags = translateNlpTags(getWordType(word.wordProperties?.berlinerisch ?? ''));

const hasImages = Boolean(wordProps?.images && wordProps.images.nodes.length > 0);
const hasAnagrams = anagramsResult.length > 0;
const berlinerisch = wordProps?.berlinerisch ?? '';
const hasOrthographie = berlinerisch.length > 0;
const hasLinguistik = berlinerisch.length > 0;
const hasPhonologie = soundingWordsResult.length > 0 || similarSpellingResult.length > 0;
const hasNeighbors = alphabeticNeighborsResult.before.length > 0 || alphabeticNeighborsResult.after.length > 0;
const wortartLabel: string | undefined =
  wordTags.length > 0 ? Object.values(wordTags[0])[0]?.[0] : undefined;

const firstImage = wordProps?.images?.nodes?.[0];
const firstAudio = wordProps?.berlinerischAudio?.[0];

const ogImage = word.seo?.opengraphImage?.sourceUrl
  ? word.seo.opengraphImage
  : firstImage?.sourceUrl
    ? {
        alt: firstImage.altText || wordProps?.berlinerisch || '',
        height: firstImage.mediaDetails?.height,
        sourceUrl: firstImage.sourceUrl,
        width: firstImage.mediaDetails?.width,
      }
    : undefined;

const exampleComments = (wordProps?.examples ?? [])
  .filter((e): e is NonNullable<typeof e> => Boolean(e?.example))
  .map((e) => ({
    '@type': 'Comment',
    text: e.example as string,
    ...(e.exampleExplanation && { description: e.exampleExplanation }),
  }));

const schemaJson = () => {
  const alternateNames = (wordProps?.alternativeWords ?? [])
    .map((w) => w?.alternativeWord)
    .filter((n): n is string => Boolean(n));

  return JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'DefinedTerm',
    ...(alternateNames.length > 0 && { alternateName: alternateNames }),
    ...(exampleComments.length > 0 && { comment: exampleComments }),
    ...(word.dateGmt && { dateCreated: word.dateGmt }),
    ...(word.modifiedGmt && { dateModified: word.modifiedGmt }),
    description:
      wordDescription ??
      (wordProps?.translations ?? [])
        .map((t) => t?.translation)
        .filter(Boolean)
        .join('; '),
    ...(wordProps?.article && {
      disambiguatingDescription: `Berliner Dialektwort, ${wordProps.article}`,
    }),
    identifier: word.id,
    publisher: {
      '@type': 'Organization',
      name: 'Berliner Schnauze',
      url: canonicalUrl('/', Astro.site),
    },
    ...(firstImage?.sourceUrl && {
      image: {
        '@type': 'ImageObject',
        contentUrl: firstImage.sourceUrl,
        url: firstImage.sourceUrl,
        ...(firstImage.altText && { name: firstImage.altText }),
        ...(firstImage.caption && { caption: firstImage.caption }),
        ...(firstImage.mediaDetails?.width && { width: firstImage.mediaDetails.width }),
        ...(firstImage.mediaDetails?.height && { height: firstImage.mediaDetails.height }),
      },
    }),
    inDefinedTermSet: {
      '@type': 'DefinedTermSet',
      description: 'Wörterbuch für den Berliner Dialekt und Berliner Schnauze',
      inLanguage: 'de-DE',
      name: 'Berliner Schnauze Wörterbuch',
      url: canonicalUrl('/wort', Astro.site),
    },
    inLanguage: 'de-DE',
    mainEntityOfPage: canonicalUrl(Astro.url.pathname, Astro.site),
    name: wordProps?.berlinerisch,
    sameAs: wordProps?.learnMore || undefined,
    ...(firstAudio?.audio?.node?.mediaItemUrl && {
      subjectOf: {
        '@type': 'AudioObject',
        contentUrl: firstAudio.audio.node.mediaItemUrl,
        description: `Berliner Aussprache von „${wordProps?.berlinerisch}"`,
        encodingFormat: 'audio/mpeg',
        inLanguage: 'de-DE',
        name: `Aussprache: ${wordProps?.berlinerisch}`,
      },
    }),
    termCode: word.slug || undefined,
    url: canonicalUrl(Astro.url.pathname, Astro.site),
  });
};
---

<Layout
  content={seoData({
    seo: {
      ...(word.seo ?? {}),
      ...(wordDescription && {
        opengraphDescription: wordDescription,
        twitterDescription: wordDescription,
      }),
      ...(ogImage && { opengraphImage: ogImage }),
    },
    title: word.title ?? '',
  })}
  contentClasses='o-word'
>
  <Fragment slot='head'>
    <script set:html={schemaJson()} type='application/ld+json' />
  </Fragment>

  <nav class='c-page-topbar' aria-label='Brotkrümelpfad'>
    <Breadcrumbs indexText='Start' linkTextFormat='capitalized' truncated={true}>
      <ChevronRight height='20' slot='separator' width='20' />
    </Breadcrumbs>
  </nav>

  <article class='c-word-page'>
    <WordSidebar
      hasAnagrams={hasAnagrams}
      hasLinguistik={hasLinguistik}
      hasNeighbors={hasNeighbors}
      hasOrthographie={hasOrthographie}
      hasPhonologie={hasPhonologie}
      wordProps={wordProps}
      wordTags={wordTags}
    />

    <div class:list={['c-word-main', hasImages && 'c-word-main--with-gallery']}>
      <WordHero word={word} wordProps={wordProps} wortartLabel={wortartLabel} />

      <div class='c-word-main__content'>
        <WordSectionEtymologie wordProps={wordProps} />

        {
          wordProps && (wordProps.examples?.length ?? 0) > 0 && (
            <section class='c-section-card' id='beispiele' aria-labelledby='heading-beispiele'>
              <div class='c-section-card__header'>
                <span class='c-section-card__num'>02</span>
                <h2 class='c-section-card__title' id='heading-beispiele'>Beispiele</h2>
              </div>
              <div class='c-section-card__body'>
                <WordExamples examples={wordProps.examples} rootBemClass='c-single-word' />
              </div>
            </section>
          )
        }

        <WordSectionOrthographie
          allWords={wordRefs}
          word={berlinerisch}
        />

        <WordSectionLinguistik word={berlinerisch} />

        <WordSectionGrammatik wordTags={wordTags} />

        <WordSectionPhonologie soundingWords={soundingWordsResult} similarSpelling={similarSpellingResult} />

        <WordAnagrams anagrams={anagramsResult} />

        {
          (alphabeticNeighborsResult.before.length > 0 || alphabeticNeighborsResult.after.length > 0) && (
            <section class='c-section-card' id='navigation' aria-labelledby='heading-navigation'>
              <div class='c-section-card__header'>
                <span class='c-section-card__num'>07</span>
                <h2 class='c-section-card__title' id='heading-navigation'>Alphabetische Nachbarn</h2>
              </div>
              <div class='c-section-card__body'>
                <WordAlphabetNav neighbors={alphabeticNeighborsResult} />
              </div>
            </section>
          )
        }

        {
          wordProps?.relatedWords?.nodes && wordProps?.relatedWords?.nodes.length > 0 && (
            <section class='c-section-card' id='verwandte-worte' aria-labelledby='heading-verwandte'>
              <div class='c-section-card__body'>
                <h2 class='c-section-card__title' id='heading-verwandte'>Verwandte Worte</h2>
                <ul class='c-single-word__related-words-list'>
                  {wordProps.relatedWords.nodes
                    .filter((w) => w?.wordProperties?.berlinerisch !== wordProps?.berlinerisch)
                    .map((w): BerlinerWord[] => (
                      <li class='c-single-word__related-word'>
                        <a
                          class='c-single-word__related-word-link'
                          href={routeToWord(w?.slug ?? undefined)}
                        >
                          {w?.wordProperties?.berlinerisch}
                        </a>
                      </li>
                    ))}
                </ul>
              </div>
            </section>
          )
        }

        {
          !hasImages && wordProps?.learnMore && (
            <a
              class='c-single-word__learn-more-link'
              href={wordProps.learnMore}
              rel='noopener noreferrer'
              target='_blank'
              title='mehr zu diesem Wort auf Wikipedia'
            >
              Erfahre mehr über dieses Wort
              <span class='c-single-word__learn-more-link-icon'>
                <ExternalLink height='10' width='10' />
              </span>
            </a>
          )
        }

        <BookRecommendations />
      </div>

      {
        hasImages && (
          <aside class='c-word-gallery-col' aria-label='Bildergalerie'>
            <p class='c-word-gallery-col__label'>Bilder</p>
            <ImageGallery
              images={wordProps?.images}
              lightboxSizes={lightboxSizes}
              lightboxWidths={lightboxWidths}
              priority={true}
              sizes={gallerySizes}
              widths={galleryWidths}
            />
            {wordProps?.learnMore && (
              <a
                class='c-single-word__learn-more-link'
                href={wordProps.learnMore}
                rel='noopener noreferrer'
                target='_blank'
                title='mehr zu diesem Wort auf Wikipedia'
              >
                Erfahre mehr über dieses Wort
                <span class='c-single-word__learn-more-link-icon'>
                  <ExternalLink height='10' width='10' />
                </span>
              </a>
            )}
          </aside>
        )
      }
    </div>
  </article>

  <footer class='c-single-word__footer'>
    {
      word?.dateGmt && (
        <p class='c-single-word__created'>
          Wort erstellt am: <time datetime={word.dateGmt}>{formattedDate(word.dateGmt)}</time>
        </p>
      )
    }
    {
      word?.modifiedGmt && (
        <p class='c-single-word__modified'>
          Bearbeitet am: <time datetime={word.modifiedGmt}>{formattedDate(word.modifiedGmt)}</time>
        </p>
      )
    }
  </footer>

  <RelatedWords words={wordRefs}>
    <li>
      <RandomWordButton class:list='c-related-words__word is-random' words={wordRefs} />
    </li>
  </RelatedWords>
</Layout>

<script>
  // Sync --site-header-height so sticky topbar clears the main nav.
  // Guard against height=0 that fires during View Transition animations.
  const siteHeader = document.querySelector<HTMLElement>('.c-header');
  if (siteHeader) {
    const syncHeaderHeight = () => {
      const h = Math.round(siteHeader.getBoundingClientRect().height);
      if (h > 0) {
        document.documentElement.style.setProperty('--site-header-height', h + 'px');
      }
    };
    new ResizeObserver(syncHeaderHeight).observe(siteHeader);
  }

  // Re-sync after every View Transition navigation in case the variable was zeroed out.
  document.addEventListener('astro:page-load', () => {
    const header = document.querySelector<HTMLElement>('.c-header');
    if (header) {
      const h = Math.round(header.getBoundingClientRect().height);
      if (h > 0) {
        document.documentElement.style.setProperty('--site-header-height', h + 'px');
      }
    }
  });
</script>
