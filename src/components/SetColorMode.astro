<!-- Block until theme class is set -->
<script is:inline>
  const STORAGE_KEY = 'darkMode';
  const DARK_CLASS = 'dark';

  const getPreferredDarkMode = () => {
    const persistedValue = localStorage.getItem(STORAGE_KEY);

    if (persistedValue === 'true') return true;
    if (persistedValue === 'false') return false;

    return window.matchMedia('(prefers-color-scheme: dark)').matches;
  };

  const upsertThemeColorMeta = (targetDocument, isDark) => {
    const themeColor = isDark ? '#2b333b' : '#fad0b0';
    const metaThemeColor =
      targetDocument.querySelector("meta[name='theme-color']") ||
      targetDocument.createElement('meta');

    metaThemeColor.setAttribute('name', 'theme-color');
    metaThemeColor.setAttribute('content', themeColor);

    if (!metaThemeColor.parentElement) {
      targetDocument.head.appendChild(metaThemeColor);
    }
  };

  const applyThemeToDocument = (targetDocument) => {
    const isDarkMode = getPreferredDarkMode();

    // Set class and native form controls color scheme before first paint.
    targetDocument.documentElement.classList.toggle(DARK_CLASS, isDarkMode);
    targetDocument.documentElement.style.colorScheme = isDarkMode ? 'dark' : 'light';

    upsertThemeColorMeta(targetDocument, isDarkMode);

    if (localStorage.getItem(STORAGE_KEY) === null) {
      localStorage.setItem(STORAGE_KEY, String(isDarkMode));
    }
  };

  const applyTheme = () => applyThemeToDocument(document);

  applyTheme();

  document.addEventListener('astro:before-swap', (event) => {
    const newDocument = event?.newDocument || event?.detail?.newDocument;
    if (newDocument) {
      applyThemeToDocument(newDocument);
    }
  });

  document.addEventListener('astro:after-swap', applyTheme);
</script>
