---
import { Picture } from 'astro:assets';

interface ImageBlockAttributes {
  url?: string | null;
  width?: string | null;
  height?: string | null;
  alt?: string | null;
}

interface Props {
  block: {
    attributes?: unknown;
  };
}

const { block } = Astro.props as Props;
const attrs = block.attributes as ImageBlockAttributes | null | undefined;
---

{attrs?.url && (
  <Picture
    alt={attrs.alt ?? ''}
    class='c-magazin-article__image'
    densities={[1, 2]}
    formats={['avif', 'webp']}
    height={Number(attrs.height) || 400}
    loading='lazy'
    src={attrs.url}
    width={Number(attrs.width) || 800}
  />
)}
