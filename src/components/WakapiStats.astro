---
import { WAKAPI_API_KEY } from 'astro:env/server';
import { WAKAPI_HOST } from 'astro:env/client';

let hours = 0;
let minutes = 0;

if (WAKAPI_API_KEY) {
  try {
    const res = await fetch(
      `${WAKAPI_HOST}/api/summary?interval=any&project=berliner-schnauze`,
      {
        headers: {
          Authorization: `Bearer ${Buffer.from(WAKAPI_API_KEY).toString('base64')}`,
        },
      },
    );

    if (res.ok) {
      const json = await res.json();
      const raw: number = json.projects?.[0]?.total ?? 0;
      const totalSeconds = raw > 1e9 ? Math.floor(raw / 1e9) : raw;
      hours = Math.floor(totalSeconds / 3600);
      minutes = Math.floor((totalSeconds % 3600) / 60);
    }
  } catch {
    // non-essential
  }
}
---

{(hours > 0 || minutes > 0) && <> · ⌨️ {hours} Std. {minutes} Min. Coding-Zeit</>}
