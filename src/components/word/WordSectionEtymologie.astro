---
import '@styles/components/_section-card.scss';
import '@styles/components/_word-section-etymologie.scss';
import type { BerlinerWord } from '@/gql/entity-types';

interface Props {
  wordProps: BerlinerWord['wordProperties'];
}

const { wordProps } = Astro.props;

const alternativeWords = wordProps?.alternativeWords?.map((word, index) => {
  return (
    word?.alternativeWord +
    (wordProps?.alternativeWords && index !== wordProps?.alternativeWords?.length - 1 ? ', ' : '')
  );
});

// ACF checkbox choices may carry a link as "Label : https://…" — split only
// on the spaced colon so titles like "Berlinisch: Lexikon" stay intact.
const sources = (wordProps?.sources ?? [])
  .flatMap((row) => row?.quelle ?? [])
  .filter((s): s is string => Boolean(s))
  .map((raw) => {
    const [label, url] = raw.split(' : ');
    return url?.startsWith('http') ? { label: label ?? raw, url } : { label: raw, url: null };
  });

const hasContent =
  Boolean(wordProps?.infoText) ||
  (wordProps?.alternativeWords?.length ?? 0) > 0 ||
  (wordProps?.translations?.length ?? 0) > 0 ||
  sources.length > 0;
---

{hasContent && <section class='c-section-card' id='etymologie' aria-labelledby='heading-etymologie'>
  <div class='c-section-card__header'>
    <span class='c-section-card__num'></span>
    <h2 class='c-section-card__title' id='heading-etymologie'>Etymologie</h2>
  </div>
  <div class='c-section-card__body'>
    {
      (wordProps?.alternativeWords?.length || wordProps?.translations?.length) && (
        <dl class='c-single-word__definitions'>
          {wordProps?.translations && wordProps.translations.length > 0 && (
            <>
              <dt class='c-single-word__sub-headline'>{wordProps.translations.length === 1 ? 'Bedeutung' : 'Bedeutungen'}</dt>
              {wordProps.translations.length === 1 ? (
                <dd class='c-single-word__translation-item'>{wordProps.translations[0]?.translation}</dd>
              ) : (
                <dd class='c-single-word__translation-item'>
                  <ol class='c-single-word__translation-list'>
                    {wordProps.translations.map((translation) => (
                      <li>{translation?.translation}</li>
                    ))}
                  </ol>
                </dd>
              )}
            </>
          )}
          {wordProps?.alternativeWords && wordProps.alternativeWords.length > 0 && (
            <>
              <dt class='c-single-word__sub-headline'>Selbe Bedeutung wie</dt>
              <dd class='c-single-word__alternative-word'>{alternativeWords}</dd>
            </>
          )}
        </dl>
      )
    }
    {
      wordProps?.infoText && (
        <div class='c-section-card__infotext' set:html={wordProps.infoText} />
      )
    }
  </div>
  {
    sources.length > 0 && (
      <footer class='c-word-sources'>
        <span class='c-word-sources__label'>{sources.length === 1 ? 'Quelle' : 'Quellen'}</span>
        <ul class='c-word-sources__list'>
          {sources.map((source) => (
            <li class='c-word-sources__item'>
              {source.url ? (
                <a class='c-word-sources__link' href={source.url} rel='noopener'>
                  {source.label}
                </a>
              ) : (
                source.label
              )}
            </li>
          ))}
        </ul>
      </footer>
    )
  }
</section>}
