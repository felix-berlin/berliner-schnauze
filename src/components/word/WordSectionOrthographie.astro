---
import WordDecomposition from '@components/word/WordDecomposition.astro';
import german from 'hyphenation.de';
import Hypher from 'hypher';
import type { BerlinerWord } from '@/gql/entity-types';

interface Props {
  word: string;
  allWords: BerlinerWord[];
}

const { word, allWords } = Astro.props;
const hypher = new Hypher(german);
---

<section class='c-section-card' id='orthographie' aria-labelledby='heading-orthographie'>
  <div class='c-section-card__header'>
    <span class='c-section-card__num'>03</span>
    <h2 class='c-section-card__title' id='heading-orthographie'>Orthographie</h2>
  </div>
  <div class='c-section-card__body'>
    <dl class='c-single-word__syllables'>
      <dt>Silbentrennung</dt>
      <dd set:html={hypher.hyphenate(word).join(" <span class='is-divider'>|</span> ")}></dd>
      <dt>Anzahl der Silben</dt>
      <dd>{hypher.hyphenate(word).length}</dd>
    </dl>
    <WordDecomposition allWords={allWords} word={word} />
  </div>
</section>
