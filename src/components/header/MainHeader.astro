---
import "@styles/components/_menu-nav.scss";
import ColorModeToggle from "@components/ColorModeToggle.vue";
import MainMenu from "@components/header/MainMenu.vue";
import MainMenuButton from "@components/MainMenuButton.vue";
import SearchModalTrigger from "@components/modals/search/SearchModalTrigger.vue";
const isIndex = Astro.url.pathname === "/";
---

<header class="c-header">
  <div class="c-header__wrapper u-max-body-width">
    <div class="c-logo">
      <a class="c-logo__link" href="/"> Berliner Schnauze</a>
    </div>

    <nav class="c-menu-nav">
      {!isIndex && <SearchModalTrigger client:load />}

      <ColorModeToggle client:only="vue" cssClasses={"c-menu-nav__item c-menu-nav__item-button"}>
        <button
          class="c-color-mode-toggle c-button c-button--center-icon"
          slot="fallback"
          type="button"
        >
          <svg viewBox="0 0 24 24" width="24" height="24"><path fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 2v2m2.837 12.385a6 6 0 1 1-7.223-7.222c.624-.147.97.66.715 1.248a4 4 0 0 0 5.26 5.259c.589-.255 1.396.09 1.248.715M16 12a4 4 0 0 0-4-4m7-3l-1.256 1.256M20 12h2"></path></svg>
        </button>
      </ColorModeToggle>

      <MainMenu client:only="vue">
        <MainMenuButton slot="fallback" />
      </MainMenu>
    </nav>
  </div>
</header>
