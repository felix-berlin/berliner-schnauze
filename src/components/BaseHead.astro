---
import SetColorMode from '@components/SetColorMode.astro';
import { Font } from 'astro:assets';
import { ClientRouter } from 'astro:transitions';
import { pwaInfo } from 'virtual:pwa-info';

import { canonicalUrl } from '@utils/helpers';
import type { Seo, SeoProps, Title } from '@/types/seo';

export type { Seo, SeoProps, Title };

const { seo, title } = Astro.props as SeoProps & Title;
const canonicalURL = seo?.canonical?.trim()
  ? seo.canonical.replace(/\/$/, '')
  : canonicalUrl(Astro.url.pathname, Astro.site);
---

<!-- Global Metadata -->
<meta charset='utf-8' />
<meta content='width=device-width, initial-scale=1' name='viewport' />
<SetColorMode />

<title>
  {seo?.title || title}
</title>

<Font cssVariable="--font-berliner" preload />
<Font cssVariable="--font-berlin" preload />

<script src='../plugins/sentryBrowser.ts'></script>

<ClientRouter />

<script src='/src/lib/unsupportedBrowser.ts'></script>

{pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
<script src='/src/services/pwa.ts'></script>

<!-- Favicon -->
<link href='/favicons/favicon.ico' rel='icon' sizes='48x48' />
<link href='/favicons/favicon.svg' rel='icon' sizes='any' type='image/svg+xml' />
<link href='/favicons/apple-touch-icon-180x180.png' rel='apple-touch-icon' />
<link color='#303956' href='/favicons/safari-pinned-tab.svg' rel='mask-icon' />

<link href='/sitemap-index.xml' rel='sitemap' />
<link href={canonicalURL} rel='canonical' />

<meta content='#ffffff' name='msapplication-TileColor' />
<meta content={Astro.generator} name='generator' />

<!-- Primary Meta Tags -->

{seo?.opengraphDescription && <meta content={seo?.opengraphDescription} name='description' />}

<!-- Open Graph / Facebook -->
{seo?.opengraphSiteName && <meta content={seo?.opengraphSiteName} property='og:site_name' />}
{seo?.opengraphType && <meta content={seo?.opengraphType} property='og:type' />}
<meta content={canonicalURL} property='og:url' />
{
  (seo?.opengraphTitle || seo?.title || title) && (
    <meta content={seo?.opengraphTitle || seo?.title || title} property='og:title' />
  )
}
{
  seo?.opengraphDescription && (
    <meta content={seo?.opengraphDescription} property='og:description' />
  )
}
{
  seo?.opengraphImage?.sourceUrl && (
    <>
      <meta content={seo?.opengraphImage?.sourceUrl} property='og:image' />
      <meta
        content={seo?.opengraphImage?.alt ?? (seo?.opengraphTitle || seo?.title || title) ?? ''}
        property='og:image:alt'
      />
      {seo?.opengraphImage?.width && (
        <meta content={seo?.opengraphImage?.width} property='og:image:width' />
      )}
      {seo?.opengraphImage?.height && (
        <meta content={seo?.opengraphImage?.height} property='og:image:height' />
      )}
      {seo?.opengraphImage?.type && (
        <meta content={seo?.opengraphImage?.type} property='og:image:type' />
      )}
    </>
  )
}

<!-- Twitter -->
<meta content='summary_large_image' name='twitter:card' />
<meta content={canonicalURL} name='twitter:url' />
{
  (seo?.twitterTitle || seo?.title || title) && (
    <meta content={seo?.twitterTitle || seo?.title || title} name='twitter:title' />
  )
}
{
  (seo?.twitterDescription || seo?.opengraphDescription) && (
    <meta
      content={seo?.twitterDescription || seo?.opengraphDescription}
      name='twitter:description'
    />
  )
}
{
  seo?.opengraphImage?.sourceUrl && (
    <meta content={seo?.opengraphImage?.sourceUrl} name='twitter:image' />
  )
}

<!-- Locale -->
<meta content='de_DE' property='og:locale' />

<!-- Article times -->
{seo?.opengraphPublishedTime && <meta property='article:published_time' content={seo.opengraphPublishedTime} />}
{seo?.opengraphModifiedTime && <meta property='article:modified_time' content={seo.opengraphModifiedTime} />}

<!-- Mastodon -->
<meta content='@berliner_schnauze@mastodon.social' name='fediverse:creator' />
