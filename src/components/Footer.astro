---
import BearWalking from '@assets/images/bear-walking.png';
import CarbonBadge from '@components/CarbonBadge.vue';
import FooterAppSection from '@components/FooterAppSection.vue';
import NavList from '@components/NavList.vue';
import { Picture } from 'astro:assets';
import WakapiStats from '@components/WakapiStats.astro';
import { fetchSocialMenu } from '@services/queries/getCompanySocialMedia';
import { fetchMenu } from '@services/queries/getMenu';

import { funding, version } from '../../package.json';

// const randomWord = () => {
//   // TODO: Implement random word
//   // return randomElement(berlinerWords).post_name;
// };
//
//
const socialMenu = await fetchSocialMenu();
const fundingMenu = [
  {
    link: funding.find((f) => f.type === 'GitHub Sponsors')?.url ?? '',
    title: 'GitHub Sponsors',
  },
  {
    link: funding.find((f) => f.type === 'Ko-fi')?.url ?? '',
    title: 'Ko-fi',
  },
  {
    link: funding.find((f) => f.type === 'PayPal')?.url ?? '',
    title: 'PayPal',
  },
];

const navMenu1 = await fetchMenu('Footer Nav 1');

const navMenu2 = await fetchMenu('Footer Nav 2');
---

<footer class='c-footer'>
  <div class='c-footer__farewell u-max-body-width'>
    <div class='c-footer__farewell-image-wrapper'>
      <Picture
        alt='Ein Bär der durch die Stadt läuft'
        class='c-footer__farewell-image'
        formats={['avif', 'webp']}
        layout='constrained'
        sizes="(min-width: 1024px) 40vw, 50vw"
        src={BearWalking}
      />
    </div>
    <p class='c-footer__farewell-text'>Knorke ditt du mich hier unten besuchst.</p>
  </div>

  <div class='c-footer__ground'>
    <div class='c-footer__wrapper u-max-body-width'>
      <div class='c-footer__ground-app-install'>
        <FooterAppSection client:only='vue' />
      </div>

      <div>
        <h2>Seiten</h2>
        <NavList
          ariaLabel='Seiten'
          classesNav={'c-footer__nav'}
          classesUl={'c-footer__nav-list u-list-reset'}
          items={navMenu1}
        />
      </div>

      <div
        data-track-content
        data-content-name='Footer Funding CTA'
        data-content-piece='Projekt unterstützen'
        data-content-target={fundingMenu[0].link}
      >
        <h2>Projekt unterstützen</h2>
        <NavList
          ariaLabel='Projekt unterstützen'
          classesNav={'c-footer__nav'}
          classesUl={'c-footer__nav-list u-list-reset'}
          items={fundingMenu}
        />
      </div>

      <div>
        <h2>Social Media</h2>
        <NavList
          ariaLabel='Social Media'
          classesNav={'c-footer__nav'}
          classesUl={'c-footer__nav-list u-list-reset'}
          items={socialMenu}
        />
      </div>

      <div>
        <h2>Andere</h2>
        <NavList
          ariaLabel='Andere'
          classesNav={'c-footer__nav is-legal'}
          classesUl={'c-footer__nav-list u-list-reset'}
          items={navMenu2}
        />
      </div>
    </div>
  </div>
</footer>
<div class='c-footer__end'>
  <div class='c-footer__end-content u-max-body-width'>
    <a href='https://github.com/felix-berlin/berliner-schnauze/releases'
      >Website Version: {version}</a
    >
    <p>Ein Projekt von: <a href='https://webshaped.de'>Webshaped / Felix Scholze</a></p>
    <CarbonBadge />
    <p>Hergestellt mit🐻-Kräften in Berlin</p>
    <WakapiStats />
  </div>
</div>
