/*
  Cache-Control: public, max-age=3600, stale-while-revalidate=86400
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=()
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline' https://pulse.berliner-schnauze.wtf https://static.cloudflareinsights.com; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https://cms.berliner-schnauze.wtf https://*.sentry.io https://sentry.io https://pulse.berliner-schnauze.wtf https://cloudflareinsights.com; font-src 'self'; frame-ancestors 'none'
  Content-Signal: search=yes, ai-train=no
  TDM-Reservation: 1

/_astro/*
  Cache-Control: public, max-age=31536000, immutable
